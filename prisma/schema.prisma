generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DELETED
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  DOCUMENTS_REQUIRED
  SENT_TO_PARTNER
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  RESCHEDULED
  CANCELLED
  NO_SHOW
  COMPLETED
  REFUNDED
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum LeadStatus {
  NEW
  OTP_VERIFIED
  CONTACTED
  QUALIFIED
  HOT
  COUNSELING_BOOKED
  APPLICATION_STARTED
  DOCUMENTS_PENDING
  APPLIED
  OFFER_RECEIVED
  ADMITTED
  ENROLLED
  LOST
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique // SUPER_ADMIN, ADMIN, MANAGEMENT, EDITOR, COUNSELOR, STUDENT
  description String?
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  roles       Role[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  phone         String?    @unique
  image         String?
  password      String?
  roleId        String?
  role          Role?      @relation(fields: [roleId], references: [id])
  status        UserStatus @default(ACTIVE)
  emailVerified DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  accounts             Account[]
  sessions             Session[]
  studentProfile       StudentProfile?
  staffProfile         StaffProfile?
  savedInstitutions    SavedInstitution[]
  applications         Application[]         @relation("StudentApplications")
  reviews              Review[]
  bookingsAsStudent    MentorshipBooking[]   @relation("StudentBookings")
  bookingsAsCounselor  MentorshipBooking[]   @relation("CounselorBookings")
  assignedStudents     CounselorAssignment[] @relation("CounselorAssignments")
  counselorAssignments CounselorAssignment[] @relation("StudentAssignments")
  
  crmNotesAuthored     CrmNote[]             @relation("CrmNoteAuthor")
  crmNotesForStudent   CrmNote[]             @relation("CrmNotesForStudent")
  
  crmTasksAsStudent    CrmTask[]             @relation("CrmTasksForStudent")
  crmTasksAsCounselor  CrmTask[]             @relation("CrmTasksForCounselor")
  
  callLogsAsStudent    CallLog[]             @relation("CallLogsForStudent")
  callLogsAsCounselor  CallLog[]             @relation("CallLogsForCounselor")

  auditLogs            AuditLog[]
  payments             Payment[]
  leadsAssigned        Lead[]                @relation("AssignedLeads")
  leadsCreated         Lead[]                @relation("LeadStudentUser")
  notifications        Notification[]
  questions            Question[]
  answers              Answer[]
  universityPartner    UniversityPartner?
  blogPosts            BlogPost[]
  downloads            Download[]
  comparisons          Comparison[]
  reports              Report[]

  @@index([roleId])
  @@index([status])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model StudentProfile {
  id                    String          @id @default(cuid())
  userId                String          @unique
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  highestQualification  String?
  currentCity           String?
  budget                String?
  preferredCategory     String?
  preferredLocation     String?
  leads                 Lead[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

model StaffProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio             String?
  specialties     String[] // Online, Offline, Study Abroad, Distance
  languages       String[]
  experienceYears Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Institution {
  id                    String            @id @default(cuid())
  name                  String
  slug                  String            @unique
  type                  String            @default("COLLEGE") // COLLEGE, UNIVERSITY, INSTITUTE, PLATFORM
  logo                  String?
  coverImage            String?
  gallery               String[]
  shortDescription      String?
  fullDescription       String?           @db.Text
  country               String            @default("India")
  state                 String?
  city                  String?
  address               String?
  websiteUrl            String?
  approvalAccreditation String[]
  ranking               Json?
  admissionProcess      String?           @db.Text
  eligibility           String?           @db.Text
  scholarships          String?           @db.Text
  faqs                  Json?
  status                PublishStatus     @default(DRAFT)
  
  seoTitle              String?
  seoDescription        String?
  seoKeywords           String[]

  categories            Category[]
  programs              Program[]
  customValues          CustomFieldValue[]
  leads                 Lead[]            @relation("InterestedInstitution")
  media                 FileAsset[]
  reviews               Review[]
  savedBy               SavedInstitution[]
  applications          Application[]
  universityId          String?
  university            University?       @relation(fields: [universityId], references: [id], onDelete: SetNull)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([name])
  @@index([status])
}

model Program {
  id            String             @id @default(cuid())
  name          String
  slug          String             @unique
  degreeLevel   String?
  stream        String?
  duration      String?
  fees          Json?
  status        PublishStatus      @default(DRAFT)
  
  institutionId String
  institution   Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  categories    Category[]
  customValues  CustomFieldValue[]
  leads         Lead[]             @relation("InterestedProgram")
  applications  Application[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([name])
  @@index([status])
}

model Category {
  id           String        @id @default(cuid())
  name         String        @unique // Offline Colleges, Online Programs, Study Abroad, Distance Learning
  slug         String        @unique // offline-colleges, online-programs, study-abroad, distance-learning
  description  String?
  fieldGroups  FieldGroup[]
  institutions Institution[]
  programs     Program[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model FieldGroup {
  id         String                   @id @default(cuid())
  name       String
  categoryId String
  category   Category                 @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  fields     CustomFieldDefinition[]
  order      Int                      @default(0)
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
}

model CustomFieldDefinition {
  id           String             @id @default(cuid())
  name         String
  key          String
  type         String             // TEXT, NUMBER, DROPDOWN, MULTI_SELECT, DATE, FILE, IMAGE, RICH_TEXT, REPEATABLE, COMPARISON, SEO
  isRequired   Boolean            @default(false)
  options      Json?              // Dropdown/multi-select options list
  fieldGroupId String
  fieldGroup   FieldGroup         @relation(fields: [fieldGroupId], references: [id], onDelete: Cascade)
  order        Int                @default(0)
  customValues CustomFieldValue[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model CustomFieldValue {
  id                String                @id @default(cuid())
  institutionId     String?
  institution       Institution?          @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  programId         String?
  program           Program?              @relation(fields: [programId], references: [id], onDelete: Cascade)
  fieldDefinitionId String
  fieldDefinition   CustomFieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)
  value             Json                  // Serialized custom field value
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([institutionId, fieldDefinitionId])
  @@unique([programId, fieldDefinitionId])
}

model Lead {
  id                   String          @id @default(cuid())
  fullName             String
  phone                String
  email                String
  currentCity          String
  preferredCourse      String
  preferredCategory    String          // OFFLINE, ONLINE, STUDY_ABROAD, DISTANCE
  preferredLocation    String?
  budget               String?
  highestQualification String?
  status               LeadStatus      @default(NEW)
  
  assignedCounselorId  String?
  assignedCounselor    User?           @relation("AssignedLeads", fields: [assignedCounselorId], references: [id], onDelete: SetNull)
  
  studentProfileId     String?
  studentProfile       StudentProfile? @relation(fields: [studentProfileId], references: [id], onDelete: SetNull)
  
  interestedInstitutionId String?
  interestedInstitution   Institution? @relation("InterestedInstitution", fields: [interestedInstitutionId], references: [id], onDelete: SetNull)

  interestedProgramId     String?
  interestedProgram       Program?     @relation("InterestedProgram", fields: [interestedProgramId], references: [id], onDelete: SetNull)

  createdStudentUserId String?
  createdStudentUser   User?           @relation("LeadStudentUser", fields: [createdStudentUserId], references: [id], onDelete: SetNull)

  activities           LeadActivity[]
  downloads            Download[]
  comparisons          Comparison[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([email])
  @@index([phone])
}

model LeadActivity {
  id           String   @id @default(cuid())
  leadId       String
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  activityType String   // DOWNLOAD_BROCHURE, COMPARE, BOOK_COUNSELING, VIEW_FEE, etc.
  description  String
  pageUrl      String?
  ctaClicked   String?
  utmSource    String?
  device       String?
  timestamp    DateTime @default(now())
}

model OTPVerification {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  expiresAt DateTime
  attempts  Int      @default(0)
  status    String   @default("PENDING") // PENDING, VERIFIED, EXPIRED, FAILED
  createdAt DateTime @default(now())
}

model Application {
  id              String            @id @default(cuid())
  studentId       String
  student         User              @relation("StudentApplications", fields: [studentId], references: [id], onDelete: Cascade)
  institutionId   String
  institution     Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  programId       String?
  program         Program?          @relation(fields: [programId], references: [id], onDelete: SetNull)
  status          ApplicationStatus @default(DRAFT)
  notes           String?
  submittedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([studentId])
  @@index([institutionId])
  @@index([programId])
}

model CounselorAssignment {
  id          String   @id @default(cuid())
  studentId   String
  counselorId String
  assignedAt  DateTime @default(now())
  endedAt     DateTime?

  student   User @relation("StudentAssignments", fields: [studentId], references: [id], onDelete: Cascade)
  counselor User @relation("CounselorAssignments", fields: [counselorId], references: [id], onDelete: Cascade)
}

model CrmNote {
  id        String   @id @default(cuid())
  studentId String
  student   User     @relation("CrmNotesForStudent", fields: [studentId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("CrmNoteAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  body      String
  isPrivate Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CrmTask {
  id          String       @id @default(cuid())
  studentId   String
  student     User         @relation("CrmTasksForStudent", fields: [studentId], references: [id], onDelete: Cascade)
  counselorId String
  counselor   User         @relation("CrmTasksForCounselor", fields: [counselorId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueAt       DateTime?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(OPEN)
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model CallLog {
  id          String   @id @default(cuid())
  studentId   String
  student     User     @relation("CallLogsForStudent", fields: [studentId], references: [id], onDelete: Cascade)
  counselorId String
  counselor   User     @relation("CallLogsForCounselor", fields: [counselorId], references: [id], onDelete: Cascade)
  outcome     String?
  notes       String?
  calledAt    DateTime @default(now())
  durationSec Int?
}

model MentorshipBooking {
  id             String        @id @default(cuid())
  studentId      String
  counselorId    String
  topic          String
  startsAt       DateTime
  endsAt         DateTime
  timezone       String        @default("Asia/Kolkata")
  status         BookingStatus @default(PENDING_PAYMENT)
  meetingUrl     String?
  studentNotes   String?
  counselorNotes String?
  amount         Int           @default(0)
  currency       String        @default("INR")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  student   User      @relation("StudentBookings", fields: [studentId], references: [id], onDelete: Cascade)
  counselor User      @relation("CounselorBookings", fields: [counselorId], references: [id], onDelete: Restrict)
  payments  Payment[]
}

model Payment {
  id                String        @id @default(cuid())
  userId            String
  bookingId         String?
  provider          String        @default("RAZORPAY")
  providerOrderId   String?       @unique
  providerPaymentId String?       @unique
  amount            Int
  currency          String        @default("INR")
  status            PaymentStatus @default(CREATED)
  metadata          Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user    User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  booking MentorshipBooking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
}

model FileAsset {
  id            String       @id @default(cuid())
  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  ownerUserId   String?
  bucket        String
  key           String       @unique
  url           String?
  mimeType      String?
  sizeBytes     Int?
  purpose       String?
  isPublic      Boolean      @default(false)
  createdAt     DateTime     @default(now())
  downloads     Download[]
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
}

model Notification {
  id        String    @id @default(cuid())
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String?   // Target role if broadcasted
  title     String
  body      String
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedBy String?
  updatedAt DateTime @updatedAt
}

model Exam {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  category      String
  syllabus      String?   @db.Text
  pattern       String?   @db.Text
  examDate      DateTime?
  resultDate    DateTime?
  cutoffDetails Json?
  faqs          Json?
  createdAt     DateTime  @default(now())
}

model Question {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  body       String   @db.Text
  category   String
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  answers    Answer[]
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body       String   @db.Text
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model BlogPost {
  id              String   @id @default(cuid())
  authorId        String
  author          User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  title           String
  slug            String   @unique
  category        String
  content         String   @db.Text
  metaTitle       String?
  metaDescription String?
  isPublished     Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model Review {
  id                  String       @id @default(cuid())
  userId              String
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  institutionId       String
  institution         Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  ratingOverall       Int
  ratingAcademics     Int?
  ratingPlacements    Int?
  ratingCampus        Int?
  ratingHostel        Int?
  ratingFaculty       Int?
  ratingValueForMoney Int?
  title               String?
  body                String
  status              ReviewStatus @default(PENDING)
  isVerified          Boolean      @default(false)
  moderationReason    String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model SavedInstitution {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([userId, institutionId])
}

model Download {
  id          String     @id @default(cuid())
  leadId      String?
  lead        Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)
  studentId   String?
  student     User?      @relation(fields: [studentId], references: [id], onDelete: SetNull)
  fileAssetId String?
  fileAsset   FileAsset? @relation(fields: [fileAssetId], references: [id], onDelete: SetNull)
  ipAddress   String?
  createdAt   DateTime   @default(now())
}

model Comparison {
  id             String   @id @default(cuid())
  leadId         String?
  lead           Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  studentId      String?
  student        User?    @relation(fields: [studentId], references: [id], onDelete: SetNull)
  category       String
  institutionIds String[]
  createdAt      DateTime @default(now())
}

model Report {
  id           String   @id @default(cuid())
  title        String
  type         String // LEAD_REPORT, COUNSELOR_PERFORMANCE, etc.
  url          String?
  generatedById String?
  generatedBy  User?    @relation(fields: [generatedById], references: [id], onDelete: SetNull)
  payload      Json?
  createdAt    DateTime @default(now())
}

model SEO {
  id             String   @id @default(cuid())
  title          String
  description    String
  keywords       String[]
  canonicalUrl   String?
  ogTitle        String?
  ogDescription  String?
  ogImage        String?
  ogType         String?
  faqSchema      Json?
  courseSchema   Json?
  orgSchema      Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PageSection {
  id          String   @id @default(cuid())
  pageName    String // e.g. "home", "colleges"
  sectionKey  String // e.g. "hero", "popular-colleges"
  title       String?
  subtitle    String?
  content     Json?
  order       Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  userId     String?
  eventName  String
  entityType String?
  entityId   String?
  properties Json?
  createdAt  DateTime @default(now())
}

model StudyAbroadCountry {
  id              String      @id @default(cuid())
  name            String      @unique
  slug            String      @unique
  averageCost     String
  visaProcess     String      @db.Text
  jobProspects    String      @db.Text
  scholarships    String      @db.Text
  faqs            Json?
  createdAt       DateTime    @default(now())
}

model University {
  id              String              @id @default(cuid())
  name            String
  slug            String              @unique
  description     String?
  logoUrl         String?
  websiteUrl      String?
  createdAt       DateTime            @default(now())
  colleges        Institution[]
  partners        UniversityPartner[]
}

model UniversityPartner {
  id              String      @id @default(cuid())
  userId          String      @unique
  universityId    String
  position        String?
  isActive        Boolean     @default(true)
  
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  university      University  @relation(fields: [universityId], references: [id], onDelete: Cascade)
}
