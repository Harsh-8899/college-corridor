generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DELETED
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  DOCUMENTS_REQUIRED
  SENT_TO_PARTNER
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  RESCHEDULED
  CANCELLED
  NO_SHOW
  COMPLETED
  REFUNDED
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum LeadStatus {
  NEW
  OTP_VERIFIED
  CONTACTED
  QUALIFIED
  HOT
  COUNSELING_BOOKED
  COUNSELING_SCHEDULED
  APPLICATION_STARTED
  DOCUMENTS_PENDING
  APPLICATION_SUBMITTED
  ADMISSION_OFFERED
  ADMISSION_CONFIRMED
  APPLIED
  OFFER_RECEIVED
  ADMITTED
  ENROLLED
  LOST
  ELIGIBLE
  ALTERNATIVE_SUGGESTED
  CLOSED
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique // SUPER_ADMIN, ADMIN, MANAGEMENT, EDITOR, COUNSELOR, STUDENT
  description String?
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  roles       Role[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  phone         String?    @unique
  image         String?
  password      String?
  roleId        String?
  role          Role?      @relation(fields: [roleId], references: [id])
  status        UserStatus @default(ACTIVE)
  emailVerified DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  accounts             Account[]
  sessions             Session[]
  studentProfile       StudentProfile?
  staffProfile         StaffProfile?
  savedInstitutions    SavedInstitution[]
  applications         Application[]         @relation("StudentApplications")
  reviews              Review[]
  bookingsAsStudent    MentorshipBooking[]   @relation("StudentBookings")
  bookingsAsCounselor  MentorshipBooking[]   @relation("CounselorBookings")
  assignedStudents     CounselorAssignment[] @relation("CounselorAssignments")
  counselorAssignments CounselorAssignment[] @relation("StudentAssignments")
  
  crmNotesAuthored     CrmNote[]             @relation("CrmNoteAuthor")
  crmNotesForStudent   CrmNote[]             @relation("CrmNotesForStudent")
  
  crmTasksAsStudent    CrmTask[]             @relation("CrmTasksForStudent")
  crmTasksAsCounselor  CrmTask[]             @relation("CrmTasksForCounselor")
  
  callLogsAsStudent    CallLog[]             @relation("CallLogsForStudent")
  callLogsAsCounselor  CallLog[]             @relation("CallLogsForCounselor")

  auditLogs            AuditLog[]
  payments             Payment[]
  leadsAssigned        Lead[]                @relation("AssignedLeads")
  leadsCreated         Lead[]                @relation("LeadStudentUser")
  notifications        Notification[]
  questions            Question[]
  answers              Answer[]
  universityPartner    UniversityPartner?
  blogPosts            BlogPost[]
  downloads            Download[]
  comparisons          Comparison[]
  reports              Report[]

  @@index([roleId])
  @@index([status])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model StudentProfile {
  id                    String          @id @default(cuid())
  userId                String          @unique
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  highestQualification  String?
  currentCity           String?
  budget                String?
  preferredCategory     String?
  preferredLocation     String?
  leads                 Lead[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

model StaffProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio             String?
  specialties     String[] // Online, Offline, Study Abroad, Distance
  languages       String[]
  experienceYears Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Institution {
  id                    String            @id @default(cuid())
  institutionId         String?
  aisheCode             String?           @unique
  name                  String
  slug                  String            @unique
  shortName             String?
  type                  String            @default("COLLEGE") // COLLEGE, UNIVERSITY, INSTITUTE, PLATFORM
  ownership             String
  approval              String?
  affiliation           String?
  establishedYear       Int?
  campusSize            String?
  genderAccepted        String?
  state                 String
  city                  String
  district              String?
  address               String?
  pincode               String?
  website               String?
  email                 String?
  phone                 String?
  logoUrl               String?
  imageUrl              String?
  brochureUrl           String?
  description           String?           @db.Text
  verificationStatus    String?           @default("PENDING")
  sourceName            String?
  sourceUrl             String?
  published             Boolean           @default(false)
  isPartner             Boolean           @default(false)
  commissionNotes       String?           @db.Text
  admissionContact      String?
  priorityLevel         String?           
  agreementStatus       String?           
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  // Relationships
  courses              InstitutionCourse[]
  placements           InstitutionPlacement[]
  rankings             InstitutionRanking[]
  admissions           InstitutionAdmission[]
  reviewSummaries      InstitutionReviewSummary[]
  facilities           InstitutionFacility[]
  scholarships         InstitutionScholarship[]
  seo                  InstitutionSeo[]
  admissionRules       AdmissionRule[]

  // Existing relations to keep the application integrated
  categories            Category[]
  programs              Program[]
  customValues          CustomFieldValue[]
  leads                 Lead[]            @relation("InterestedInstitution")
  media                 FileAsset[]
  reviews               Review[]
  savedBy               SavedInstitution[]
  applications          Application[]
  universityId          String?
  university            University?       @relation(fields: [universityId], references: [id], onDelete: SetNull)
  testimonials          Testimonial[]
  faqs                  FAQ[]
  logos                 Logo[]


  @@index([name])
  @@index([slug])
  @@index([aisheCode])
  @@index([state])
  @@index([city])
  @@index([ownership])
  @@index([type])
}

model Program {
  id            String             @id @default(cuid())
  name          String
  slug          String             @unique
  degreeLevel   String?
  stream        String?
  duration      String?
  fees          Json?
  status        PublishStatus      @default(DRAFT)
  
  institutionId String
  institution   Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  categories    Category[]
  customValues  CustomFieldValue[]
  leads         Lead[]             @relation("InterestedProgram")
  applications  Application[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([name])
  @@index([status])
}

model Category {
  id           String        @id @default(cuid())
  name         String        @unique // Offline Colleges, Online Programs, Study Abroad, Distance Learning
  slug         String        @unique // offline-colleges, online-programs, study-abroad, distance-learning
  description  String?
  fieldGroups  FieldGroup[]
  institutions Institution[]
  programs     Program[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model FieldGroup {
  id         String                   @id @default(cuid())
  name       String
  categoryId String
  category   Category                 @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  fields     CustomFieldDefinition[]
  order      Int                      @default(0)
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
}

model CustomFieldDefinition {
  id           String             @id @default(cuid())
  name         String
  key          String
  type         String             // TEXT, NUMBER, DROPDOWN, MULTI_SELECT, DATE, FILE, IMAGE, RICH_TEXT, REPEATABLE, COMPARISON, SEO
  isRequired   Boolean            @default(false)
  options      Json?              // Dropdown/multi-select options list
  fieldGroupId String
  fieldGroup   FieldGroup         @relation(fields: [fieldGroupId], references: [id], onDelete: Cascade)
  order        Int                @default(0)
  customValues CustomFieldValue[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model CustomFieldValue {
  id                String                @id @default(cuid())
  institutionId     String?
  institution       Institution?          @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  programId         String?
  program           Program?              @relation(fields: [programId], references: [id], onDelete: Cascade)
  fieldDefinitionId String
  fieldDefinition   CustomFieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)
  value             Json                  // Serialized custom field value
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([institutionId, fieldDefinitionId])
  @@unique([programId, fieldDefinitionId])
}

model Lead {
  id                   String          @id @default(cuid())
  fullName             String
  phone                String
  email                String
  currentCity          String
  preferredCourse      String
  preferredCategory    String          // OFFLINE, ONLINE, STUDY_ABROAD, DISTANCE
  preferredLocation    String?
  budget               String?
  highestQualification String?
  status               LeadStatus      @default(NEW)
  
  // Dynamic fields
  state                String?
  preferredIntakeYear  String?
  message              String?         @db.Text
  consent              Boolean         @default(true)
  sourcePage           String?
  ctaClicked           String?
  followUpDate         DateTime?
  
  // Admission checker fields
  tenthPercentage       Float?
  twelfthPercentage     Float?
  graduationPercentage  Float?
  entranceExam          String?
  entranceExamScore     String?
  preferredSpecialization String?
  admissionResult       String?
  
  assignedCounselorId  String?
  assignedCounselor    User?           @relation("AssignedLeads", fields: [assignedCounselorId], references: [id], onDelete: SetNull)
  
  studentProfileId     String?
  studentProfile       StudentProfile? @relation(fields: [studentProfileId], references: [id], onDelete: SetNull)
  
  interestedInstitutionId String?
  interestedInstitution   Institution? @relation("InterestedInstitution", fields: [interestedInstitutionId], references: [id], onDelete: SetNull)

  interestedProgramId     String?
  interestedProgram       Program?     @relation("InterestedProgram", fields: [interestedProgramId], references: [id], onDelete: SetNull)

  createdStudentUserId String?
  createdStudentUser   User?           @relation("LeadStudentUser", fields: [createdStudentUserId], references: [id], onDelete: SetNull)

  activities           LeadActivity[]
  downloads            Download[]
  comparisons          Comparison[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([email])
  @@index([phone])
}

model LeadActivity {
  id           String   @id @default(cuid())
  leadId       String
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  activityType String   // DOWNLOAD_BROCHURE, COMPARE, BOOK_COUNSELING, VIEW_FEE, etc.
  description  String
  pageUrl      String?
  ctaClicked   String?
  utmSource    String?
  device       String?
  timestamp    DateTime @default(now())
}

model OTPVerification {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  expiresAt DateTime
  attempts  Int      @default(0)
  status    String   @default("PENDING") // PENDING, VERIFIED, EXPIRED, FAILED
  createdAt DateTime @default(now())
}

model Application {
  id              String            @id @default(cuid())
  studentId       String
  student         User              @relation("StudentApplications", fields: [studentId], references: [id], onDelete: Cascade)
  institutionId   String
  institution     Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  programId       String?
  program         Program?          @relation(fields: [programId], references: [id], onDelete: SetNull)
  status          ApplicationStatus @default(DRAFT)
  notes           String?
  submittedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([studentId])
  @@index([institutionId])
  @@index([programId])
}

model CounselorAssignment {
  id          String   @id @default(cuid())
  studentId   String
  counselorId String
  assignedAt  DateTime @default(now())
  endedAt     DateTime?

  student   User @relation("StudentAssignments", fields: [studentId], references: [id], onDelete: Cascade)
  counselor User @relation("CounselorAssignments", fields: [counselorId], references: [id], onDelete: Cascade)
}

model CrmNote {
  id        String   @id @default(cuid())
  studentId String
  student   User     @relation("CrmNotesForStudent", fields: [studentId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("CrmNoteAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  body      String
  isPrivate Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CrmTask {
  id          String       @id @default(cuid())
  studentId   String
  student     User         @relation("CrmTasksForStudent", fields: [studentId], references: [id], onDelete: Cascade)
  counselorId String
  counselor   User         @relation("CrmTasksForCounselor", fields: [counselorId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueAt       DateTime?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(OPEN)
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model CallLog {
  id          String   @id @default(cuid())
  studentId   String
  student     User     @relation("CallLogsForStudent", fields: [studentId], references: [id], onDelete: Cascade)
  counselorId String
  counselor   User     @relation("CallLogsForCounselor", fields: [counselorId], references: [id], onDelete: Cascade)
  outcome     String?
  notes       String?
  calledAt    DateTime @default(now())
  durationSec Int?
}

model MentorshipBooking {
  id             String        @id @default(cuid())
  studentId      String
  counselorId    String
  topic          String
  startsAt       DateTime
  endsAt         DateTime
  timezone       String        @default("Asia/Kolkata")
  status         BookingStatus @default(PENDING_PAYMENT)
  meetingUrl     String?
  studentNotes   String?
  counselorNotes String?
  amount         Int           @default(0)
  currency       String        @default("INR")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  student   User      @relation("StudentBookings", fields: [studentId], references: [id], onDelete: Cascade)
  counselor User      @relation("CounselorBookings", fields: [counselorId], references: [id], onDelete: Restrict)
  payments  Payment[]
}

model Payment {
  id                String        @id @default(cuid())
  userId            String
  bookingId         String?
  provider          String        @default("RAZORPAY")
  providerOrderId   String?       @unique
  providerPaymentId String?       @unique
  amount            Int
  currency          String        @default("INR")
  status            PaymentStatus @default(CREATED)
  metadata          Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user    User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  booking MentorshipBooking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
}

model FileAsset {
  id            String       @id @default(cuid())
  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  ownerUserId   String?
  bucket        String
  key           String       @unique
  url           String?
  mimeType      String?
  sizeBytes     Int?
  purpose       String?
  isPublic      Boolean      @default(false)
  createdAt     DateTime     @default(now())
  downloads     Download[]
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
}

model Notification {
  id        String    @id @default(cuid())
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String?   // Target role if broadcasted
  title     String
  body      String
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedBy String?
  updatedAt DateTime @updatedAt
}

model Exam {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  category      String
  syllabus      String?   @db.Text
  pattern       String?   @db.Text
  examDate      DateTime?
  resultDate    DateTime?
  cutoffDetails Json?
  faqs          Json?
  createdAt     DateTime  @default(now())
}

model Question {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  body       String   @db.Text
  category   String
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  answers    Answer[]
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body       String   @db.Text
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model BlogPost {
  id              String   @id @default(cuid())
  authorId        String
  author          User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  title           String
  slug            String   @unique
  category        String
  content         String   @db.Text
  metaTitle       String?
  metaDescription String?
  isPublished     Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model Review {
  id                  String       @id @default(cuid())
  userId              String
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  institutionId       String
  institution         Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  ratingOverall       Int
  ratingAcademics     Int?
  ratingPlacements    Int?
  ratingCampus        Int?
  ratingHostel        Int?
  ratingFaculty       Int?
  ratingValueForMoney Int?
  title               String?
  body                String
  status              ReviewStatus @default(PENDING)
  isVerified          Boolean      @default(false)
  moderationReason    String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model SavedInstitution {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([userId, institutionId])
}

model Download {
  id          String     @id @default(cuid())
  leadId      String?
  lead        Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)
  studentId   String?
  student     User?      @relation(fields: [studentId], references: [id], onDelete: SetNull)
  fileAssetId String?
  fileAsset   FileAsset? @relation(fields: [fileAssetId], references: [id], onDelete: SetNull)
  ipAddress   String?
  createdAt   DateTime   @default(now())
}

model Comparison {
  id             String   @id @default(cuid())
  leadId         String?
  lead           Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  studentId      String?
  student        User?    @relation(fields: [studentId], references: [id], onDelete: SetNull)
  category       String
  institutionIds String[]
  createdAt      DateTime @default(now())
}

model Report {
  id           String   @id @default(cuid())
  title        String
  type         String // LEAD_REPORT, COUNSELOR_PERFORMANCE, etc.
  url          String?
  generatedById String?
  generatedBy  User?    @relation(fields: [generatedById], references: [id], onDelete: SetNull)
  payload      Json?
  createdAt    DateTime @default(now())
}

model SEO {
  id             String   @id @default(cuid())
  title          String
  description    String
  keywords       String[]
  canonicalUrl   String?
  ogTitle        String?
  ogDescription  String?
  ogImage        String?
  ogType         String?
  faqSchema      Json?
  courseSchema   Json?
  orgSchema      Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PageSection {
  id          String   @id @default(cuid())
  pageName    String // e.g. "home", "colleges"
  sectionKey  String // e.g. "hero", "popular-colleges"
  title       String?
  subtitle    String?
  content     Json?
  order       Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  userId     String?
  eventName  String
  entityType String?
  entityId   String?
  properties Json?
  createdAt  DateTime @default(now())
}

model StudyAbroadCountry {
  id              String      @id @default(cuid())
  name            String      @unique
  slug            String      @unique
  averageCost     String
  visaProcess     String      @db.Text
  jobProspects    String      @db.Text
  scholarships    String      @db.Text
  faqs            Json?
  createdAt       DateTime    @default(now())
}

model University {
  id              String              @id @default(cuid())
  name            String
  slug            String              @unique
  description     String?
  logoUrl         String?
  websiteUrl      String?
  createdAt       DateTime            @default(now())
  colleges        Institution[]
  partners        UniversityPartner[]
}

model UniversityPartner {
  id              String      @id @default(cuid())
  userId          String      @unique
  universityId    String
  position        String?
  isActive        Boolean     @default(true)
  
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  university      University  @relation(fields: [universityId], references: [id], onDelete: Cascade)
}

model InstitutionCourse {
  id                  String      @id @default(cuid())
  institutionId       String
  courseName          String
  stream              String
  level               String
  degree              String
  specialization      String?
  duration            String?
  mode                String?
  totalFees           String?
  yearlyFees          String?
  eligibility         String?     @db.Text
  examsAccepted       String?
  seats               String?
  applicationDeadline String?
  courseId            String?
  course              Course?     @relation(fields: [courseId], references: [id], onDelete: SetNull)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  institution         Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
}

model InstitutionPlacement {
  id                   String      @id @default(cuid())
  institutionId        String
  placementYear        Int?
  highestPackage       String?
  averagePackage       String?
  medianPackage        String?
  placementPercentage  String?
  topRecruiters        String?     @db.Text
  internshipOffered    String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  institution          Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
}

model InstitutionRanking {
  id             String      @id @default(cuid())
  institutionId  String
  nirfRank       String?
  nirfCategory   String?
  nirfScore      String?
  rankingYear    Int?
  otherRanking   String?     @db.Text
  rankingSource  String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  institution    Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
}

model InstitutionAdmission {
  id                 String      @id @default(cuid())
  institutionId      String
  admissionProcess   String?     @db.Text
  selectionCriteria  String?     @db.Text
  entranceExams      String?
  cutoffInfo         String?     @db.Text
  applicationMode    String?
  counsellingProcess String?     @db.Text
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  institution        Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
}

model InstitutionReviewSummary {
  id                   String      @id @default(cuid())
  institutionId        String
  overallRating        String?
  academicRating       String?
  placementRating      String?
  infrastructureRating String?
  facultyRating        String?
  hostelRating         String?
  reviewCount          String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  institution          Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
}

model InstitutionFacility {
  id             String      @id @default(cuid())
  institutionId  String
  hostel         String?
  library        String?
  sports         String?
  labs           String?
  medical        String?
  cafeteria      String?
  wifi           String?
  transport      String?
  auditorium     String?
  gym            String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  institution    Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
}

model InstitutionScholarship {
  id                   String      @id @default(cuid())
  institutionId        String
  scholarshipAvailable String?
  scholarshipDetails   String?     @db.Text
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  institution          Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
}

model InstitutionSeo {
  id                 String      @id @default(cuid())
  institutionId      String
  metaTitle          String?
  metaDescription    String?
  faqJson            Json?
  highlightsJson     Json?
  importantDatesJson Json?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  institution        Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
}

model InstitutionImportBatch {
  id          String                 @id @default(cuid())
  fileName    String
  sourceName  String
  totalRows   Int                    @default(0)
  createdRows Int                    @default(0)
  updatedRows Int                    @default(0)
  skippedRows Int                    @default(0)
  errorRows   Int                    @default(0)
  status      String                 @default("STARTED") // STARTED, COMPLETED, FAILED
  startedAt   DateTime               @default(now())
  completedAt DateTime?
  errors      InstitutionImportError[]
}

model InstitutionImportError {
  id           String                 @id @default(cuid())
  batchId      String
  rowNumber    Int
  rawData      String                 @db.Text
  errorMessage String                 @db.Text
  createdAt    DateTime               @default(now())

  batch        InstitutionImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

enum CarouselCategory {
  ONLINE
  OFFLINE
  STUDY_ABROAD
  DISTANCE
}

model CarouselSlide {
  id           String           @id @default(cuid())
  image        String
  title        String
  subtitle     String?
  buttonText   String?
  buttonLink   String?
  category     CarouselCategory
  displayOrder Int              @default(0)
  active       Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

enum LogoCategory {
  UNIVERSITY
  PARTNER
  RECRUITER
  ACCREDITATION
}

model Logo {
  id           String       @id @default(cuid())
  name         String
  image        String
  website      String?
  category     LogoCategory
  displayOrder Int          @default(0)
  active       Boolean      @default(true)
  collegeId    String?
  college      Institution? @relation(fields: [collegeId], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Testimonial {
  id           String       @id @default(cuid())
  studentName  String
  studentImage String?
  text         String       @db.Text
  rating       Int          @default(5)
  role         String?      
  isPublished  Boolean      @default(true)
  order        Int          @default(0)
  collegeId    String?
  college      Institution? @relation(fields: [collegeId], references: [id], onDelete: SetNull)
  courseId     String?      
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model FAQ {
  id          String       @id @default(cuid())
  question    String
  answer      String       @db.Text
  category    String?      
  pageName    String?      
  order       Int          @default(0)
  active      Boolean      @default(true)
  collegeId   String?
  college     Institution? @relation(fields: [collegeId], references: [id], onDelete: SetNull)
  courseId    String?      
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model PageContent {
  id              String   @id @default(cuid())
  slug            String   @unique 
  title           String
  content         String   @db.Text 
  metaTitle       String?
  metaDescription String?
  isPublished     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum BannerType {
  ANNOUNCEMENT
  HOMEPAGE
  COURSE_PAGE
  COLLEGE_PAGE
  WHATSAPP
  COUNSELING
  APPLY_NOW
}

model Banner {
  id           String     @id @default(cuid())
  type         BannerType
  image        String?
  text         String     @db.Text
  buttonText   String?
  buttonLink   String?
  displayOrder Int        @default(0)
  active       Boolean    @default(true)
  placement    String?    
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model EmailOTP {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  attempts  Int      @default(0)
  status    String   @default("PENDING") 
  createdAt DateTime @default(now())
}

model AdmissionRule {
  id                  String      @id @default(cuid())
  universityId        String
  university          Institution @relation(fields: [universityId], references: [id], onDelete: Cascade)
  courseName          String      
  specialization      String?     
  min10thPercentage   Float?
  min12thPercentage   Float?
  minGradPercentage   Float?
  entranceExam        String?     
  minEntranceScore    Float?
  eligibilityRules    String?     @db.Text
  scholarshipRules    String?     @db.Text
  alternatives        String[]    
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model Course {
  id                 String              @id @default(cuid())
  name               String              @unique 
  category           String              
  level              String              
  duration           String?
  eligibility        String?             @db.Text
  description        String?             @db.Text
  careerOutcomes     String?             @db.Text
  averageSalary      String?
  slug               String              @unique
  active             Boolean             @default(true)
  specializations    Specialization[]
  institutionCourses InstitutionCourse[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Specialization {
  id        String   @id @default(cuid())
  name      String   
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([courseId, name])
}

